SELECT g.game_pk, t_home.name AS home_team, t_away.name AS away_team
FROM dw.games g
JOIN dw.teams t_home ON g.teams__home__id = t_home.id
JOIN dw.teams t_away ON g.teams__away__id = t_away.id
WHERE g.season = '2024' AND g.game_date = '2024-04-01';
```
