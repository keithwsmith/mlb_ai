SELECT 
    t_away.name AS opponent,
    SUM(CASE WHEN g.teams__home__is_winner = 1 THEN 1 ELSE 0 END) AS wins,
    SUM(CASE WHEN g.teams__away__is_winner = 1 THEN 1 ELSE 0 END) AS losses,
    COUNT(*) AS games_played,
    CAST(SUM(CASE WHEN g.teams__home__is_winner = 1 THEN 1 ELSE 0 END) * 1.0 / NULLIF(COUNT(*), 0)) AS win_pct
FROM 
    dw.games g
    JOIN dw.teams t_home ON g.teams__home__team__id = t_home.id
    LEFT JOIN dw.teams t_away ON g.teams__away__team__id = t_away.id
