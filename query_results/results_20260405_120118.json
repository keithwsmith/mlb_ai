      "question": "player, position, team,signing bonus for the TOP 10 signing bonus for each round in 2025 draft",
      "sql": "SELECT d.pick_round AS round, d.person__full_name, d.person__primary_position__name, CAST(d.signing_bonus AS decimal(18,2)) AS signing_bonus FROM (SELECT *, ROW_NUMBER() OVER (PARTITION BY pick_round ORDER BY CAST(ISNULL(NULLIF(signing_bonus, ''), '0') AS decimal(18,2)) DESC) AS rn FROM dw.draft WHERE year = 2025 AND signing_bonus IS NOT NULL AND signing_bonus <> '') d WHERE d.rn <= 3 ORDER BY d.pick_round, CAST(d.signing_bonus AS decimal(18,2)) DESC;",
