      "question": "which team does the San Francisco Giants have the worst home record against from 2020-2025",
      "sql": "SELECT opponent,SUM(wins) AS wins,SUM(losses) AS losses,CAST(SUM(wins) AS float) / NULLIF(SUM(wins) + SUM(losses), 0) AS win_pct FROM (SELECT t_away.name AS opponent,CASE WHEN g.teams__home__is_winner = 1 THEN 1 ELSE 0 END AS wins,CASE WHEN g.teams__home__is_winner = 0 AND g.is_tie = 0 THEN 1 ELSE 0 END AS losses FROM dw.games g JOIN dw.teams t_home ON g.teams__home__team__id = t_home.id JOIN dw.teams t_away ON g.teams__away__team__id = t_away.id WHERE g.season BETWEEN '2020' AND '2025' AND g.series_description = 'Regular Season' AND g.status__detailed_state = 'Final' AND t_home.name = 'San Francisco Giants') r GROUP BY opponent ORDER BY win_pct DESC;",
